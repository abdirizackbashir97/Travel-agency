from flask import Flask, request, jsonify
from flask_cors import CORS
from dotenv import load_dotenv
import os
import sqlite3
import jwt
import bcrypt
from datetime import datetime, timedelta
from functools import wraps

load_dotenv()

app = Flask(__name__)
CORS(app, origins=["http://localhost:5173"], supports_credentials=True)

def get_db():
    conn = sqlite3.connect('database/database.db')
    conn.row_factory = sqlite3.Row
    return conn

JWT_SECRET = os.getenv('JWT_SECRET', 'your-super-secret-key')

def token_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        auth_header = request.headers.get('Authorization')
        if not auth_header or not auth_header.startswith('Bearer '):
            return jsonify({'error': 'Missing token'}), 401
        token = auth_header.split(' ')[1]
        try:
            data = jwt.decode(token, JWT_SECRET, algorithms=['HS256'])
            user_id = data['user_id']
        except:
            return jsonify({'error': 'Invalid token'}), 401
        
        conn = get_db()
        user = conn.execute("SELECT * FROM users WHERE id = ?", (user_id,)).fetchone()
        conn.close()
        if not user:
            return jsonify({'error': 'User not found'}), 401
        request.user = user
        return f(*args, **kwargs)
    return decorated

# ============ REGISTER ============
@app.route('/api/auth/register', methods=['POST'])
def register():
    try:
        data = request.get_json()
        required = ['first_name', 'second_name', 'email', 'password']
        for field in required:
            if not data.get(field):
                return jsonify({'success': False, 'message': f'{field} is required'}), 400
        
        password = data.get('password')
        if len(password) < 4:
            return jsonify({'success': False, 'message': 'Password must be at least 4 characters'}), 400
        
        hashed = bcrypt.hashpw(password.encode('utf-8'), bcrypt.gensalt()).decode('utf-8')
        
        conn = get_db()
        cur = conn.cursor()
        cur.execute('''
            INSERT INTO users (first_name, second_name, email, password, age, phone, role)
            VALUES (?, ?, ?, ?, ?, ?, 'user')
        ''', (data['first_name'], data['second_name'], data['email'].strip().lower(), hashed, data.get('age', 18), data.get('phone', '')))
        conn.commit()
        
        user_id = cur.lastrowid
        cur.execute('SELECT * FROM users WHERE id = ?', (user_id,))
        user = cur.fetchone()
        conn.close()
        
        token = jwt.encode({'user_id': user['id'], 'exp': datetime.utcnow() + timedelta(hours=24)}, JWT_SECRET, algorithm='HS256')
        
        return jsonify({'success': True, 'message': 'User registered', 'access_token': token, 'user': dict(user)})
    except sqlite3.IntegrityError:
        return jsonify({'success': False, 'message': 'Email already exists'}), 400
    except Exception as e:
        print(f"❌ Register error: {e}")
        return jsonify({'success': False, 'message': str(e)}), 500

# ============ LOGIN ============
@app.route('/api/auth/login', methods=['POST'])
def login():
    try:
        data = request.get_json()
        email = data.get('email')
        password = data.get('password')
        
        if not email or not password:
            return jsonify({'success': False, 'message': 'Email and password required'}), 400
        
        conn = get_db()
        cur = conn.cursor()
        cur.execute("SELECT * FROM users WHERE email = ?", (email.strip().lower(),))
        user = cur.fetchone()
        conn.close()
        
        if not user:
            return jsonify({'success': False, 'message': 'Invalid credentials'}), 401
        
        try:
            match = bcrypt.checkpw(password.encode('utf-8'), user['password'].encode('utf-8'))
        except:
            return jsonify({'success': False, 'message': 'Invalid credentials'}), 401
        
        if not match:
            return jsonify({'success': False, 'message': 'Invalid credentials'}), 401
        
        token = jwt.encode({'user_id': user['id'], 'exp': datetime.utcnow() + timedelta(hours=24)}, JWT_SECRET, algorithm='HS256')
        
        return jsonify({'success': True, 'message': 'Login successful', 'access_token': token, 'user': dict(user)})
    except Exception as e:
        print(f"❌ Login error: {e}")
        return jsonify({'success': False, 'message': str(e)}), 500

# ============ CREATE BOOKING ============
@app.route('/api/bookings', methods=['POST'])
@token_required
def create_booking():
    try:
        user_id = request.user['id']
        data = request.get_json()
        
        print(f"📝 Booking request: {data}")
        
        booking_type = data.get('booking_type')
        booking_id = data.get('booking_id')
        number_of_travelers = data.get('number_of_travelers', 1)
        travel_date = data.get('travel_date')
        user_details = data.get('user_details', {})
        
        if not booking_type or not booking_id:
            return jsonify({'success': False, 'message': 'Booking type and ID required'}), 400
        
        conn = get_db()
        user = conn.execute("SELECT first_name, second_name, email, phone FROM users WHERE id = ?", (user_id,)).fetchone()
        
        if booking_type == 'flight':
            item = conn.execute("SELECT id, price, airline, flight_number FROM flights WHERE id = ?", (booking_id,)).fetchone()
            if not item:
                conn.close()
                return jsonify({'success': False, 'message': 'Flight not found'}), 404
            item_name = f"{item['airline']} {item['flight_number']}"
            price = item['price']
        elif booking_type == 'hotel':
            item = conn.execute("SELECT id, price_per_night as price, hotel_name FROM hotels WHERE id = ?", (booking_id,)).fetchone()
            if not item:
                conn.close()
                return jsonify({'success': False, 'message': 'Hotel not found'}), 404
            item_name = item['hotel_name']
            price = item['price']
        elif booking_type == 'tour':
            item = conn.execute("SELECT id, price_per_person as price, tour_name FROM tours WHERE id = ?", (booking_id,)).fetchone()
            if not item:
                conn.close()
                return jsonify({'success': False, 'message': 'Tour not found'}), 404
            item_name = item['tour_name']
            price = item['price']
        else:
            conn.close()
            return jsonify({'success': False, 'message': 'Invalid booking type'}), 400
        
        total_price = price * number_of_travelers
        if not travel_date:
            travel_date = datetime.now().strftime('%Y-%m-%d')
        
        cursor = conn.execute('''
            INSERT INTO bookings (
                user_id, booking_type, booking_id, travel_date, total_price, 
                number_of_travelers, status, payment_status, 
                user_name, user_email, user_phone, special_requests, payment_method
            )
            VALUES (?, ?, ?, ?, ?, ?, 'pending', 'pending', ?, ?, ?, ?, ?)
        ''', (
            user_id, booking_type, booking_id, travel_date, total_price, 
            number_of_travelers,
            user_details.get('fullName', user['first_name'] + ' ' + user['second_name']),
            user_details.get('email', user['email']),
            user_details.get('phone', user['phone'] or ''),
            user_details.get('specialRequests', ''),
            user_details.get('paymentMethod', 'credit_card')
        ))
        conn.commit()
        booking_id_new = cursor.lastrowid
        
        notification_message = f"New {booking_type} booking #{booking_id_new}: {user['first_name']} {user['second_name']} booked {item_name}"
        conn.execute('''
            INSERT INTO notifications (user_id, title, message, is_read, created_at)
            VALUES (1, 'New Booking', ?, 0, datetime('now'))
        ''', (notification_message,))
        conn.commit()
        conn.close()
        
        print(f"✅ Booking created: #{booking_id_new}")
        
        return jsonify({'success': True, 'message': 'Booking created', 'booking_id': booking_id_new})
    except Exception as e:
        print(f"❌ Booking error: {e}")
        return jsonify({'success': False, 'message': str(e)}), 500

# ============ ADMIN UPDATE BOOKING STATUS ============
@app.route('/api/admin/bookings/<int:booking_id>/status', methods=['PUT'])
@token_required
def admin_update_booking_status(booking_id):
    try:
        if request.user['role'] != 'admin':
            return jsonify({'success': False, 'message': 'Admin only'}), 403
        
        data = request.get_json()
        new_status = data.get('status')
        
        print(f"📝 Admin updating booking #{booking_id} to: {new_status}")
        
        if new_status not in ['pending', 'confirmed', 'cancelled']:
            return jsonify({'success': False, 'message': 'Invalid status'}), 400
        
        conn = get_db()
        
        booking = conn.execute('''
            SELECT b.*, u.email, u.first_name, u.second_name
            FROM bookings b
            JOIN users u ON b.user_id = u.id
            WHERE b.id = ?
        ''', (booking_id,)).fetchone()
        
        if not booking:
            conn.close()
            return jsonify({'success': False, 'message': 'Booking not found'}), 404
        
        conn.execute("UPDATE bookings SET status = ? WHERE id = ?", (new_status, booking_id))
        conn.commit()
        
        notification_message = f"Your booking #{booking_id} has been {new_status}"
        conn.execute('''
            INSERT INTO notifications (user_id, title, message, is_read, created_at)
            VALUES (?, 'Booking Update', ?, 0, datetime('now'))
        ''', (booking['user_id'], notification_message))
        conn.commit()
        conn.close()
        
        print(f"✅ Booking #{booking_id} updated to {new_status}")
        
        return jsonify({
            'success': True, 
            'message': f'Booking #{booking_id} updated to {new_status}'
        })
    except Exception as e:
        print(f"❌ Error updating booking: {e}")
        return jsonify({'success': False, 'message': str(e)}), 500

# ============ ADMIN GET ALL BOOKINGS ============
@app.route('/api/admin/bookings', methods=['GET'])
@token_required
def admin_get_all_bookings():
    if request.user['role'] != 'admin':
        return jsonify({'success': False, 'message': 'Admin only'}), 403
    
    conn = get_db()
    bookings = conn.execute('''
        SELECT b.*, u.first_name, u.second_name, u.email, u.phone
        FROM bookings b
        JOIN users u ON b.user_id = u.id
        ORDER BY b.booking_date DESC
    ''').fetchall()
    conn.close()
    return jsonify({'success': True, 'bookings': [dict(b) for b in bookings]})

# ============ ADMIN STATS ============
@app.route('/api/admin/stats', methods=['GET'])
@token_required
def admin_get_stats():
    if request.user['role'] != 'admin':
        return jsonify({'success': False, 'message': 'Admin only'}), 403
    
    conn = get_db()
    total_bookings = conn.execute("SELECT COUNT(*) as count FROM bookings").fetchone()
    total_users = conn.execute("SELECT COUNT(*) as count FROM users").fetchone()
    revenue = conn.execute("SELECT SUM(total_price) as total FROM bookings").fetchone()
    conn.close()
    
    return jsonify({
        'success': True,
        'stats': {
            'total_bookings': total_bookings['count'] or 0,
            'total_users': total_users['count'] or 0,
            'revenue': revenue['total'] or 0
        }
    })

# ============ PUBLIC ROUTES ============
@app.route('/api/destinations', methods=['GET'])
