# ============ USER BOOKINGS ============
@app.route('/api/user/bookings', methods=['GET'])
@token_required
def get_user_bookings():
    user_id = request.user['id']
    conn = get_db()
    bookings = conn.execute("SELECT * FROM bookings WHERE user_id = ? ORDER BY booking_date DESC", (user_id,)).fetchall()
    conn.close()
    return jsonify({'success': True, 'bookings': [dict(b) for b in bookings]})

# ============ RUN ============
if __name__ == '__main__':
    app.run(debug=True, host='0.0.0.0', port=5000)

# ============ NOTIFICATIONS ============
@app.route('/api/notifications', methods=['GET'])
@token_required
def get_notifications():
    try:
        user_id = request.user['id']
        conn = get_db()
        notifications = conn.execute('''
            SELECT * FROM notifications WHERE user_id = ? ORDER BY created_at DESC LIMIT 50
        ''', (user_id,)).fetchall()
        conn.close()
        return jsonify({'success': True, 'notifications': [dict(n) for n in notifications]})
    except Exception as e:
        print(f"❌ Notifications error: {e}")
        return jsonify({'success': False, 'notifications': []}), 500

@app.route('/api/notifications/unread', methods=['GET'])
@token_required
def get_unread_count():
    try:
        user_id = request.user['id']
        conn = get_db()
        count = conn.execute('''
            SELECT COUNT(*) as count FROM notifications WHERE user_id = ? AND is_read = 0
        ''', (user_id,)).fetchone()
        conn.close()
        return jsonify({'success': True, 'count': count['count'] or 0})
    except Exception as e:
        print(f"❌ Unread count error: {e}")
        return jsonify({'success': True, 'count': 0}), 200

# ============ ADMIN RECENT BOOKINGS ============
@app.route('/api/admin/recent-bookings', methods=['GET'])
@token_required
def admin_get_recent_bookings():
    try:
        if request.user['role'] != 'admin':
            return jsonify({'success': False, 'message': 'Admin only'}), 403
        
        conn = get_db()
        bookings = conn.execute('''
            SELECT b.*, u.first_name, u.second_name, u.email
            FROM bookings b
            JOIN users u ON b.user_id = u.id
            ORDER BY b.booking_date DESC
            LIMIT 5
        ''').fetchall()
        conn.close()
        return jsonify({'success': True, 'bookings': [dict(b) for b in bookings]})
    except Exception as e:
        print(f"❌ Recent bookings error: {e}")
        return jsonify({'success': False, 'bookings': []}), 500
